rules_version = '2';

// ============================================================
// Haneulttang store manager - Firestore Security Rules
//
// Deploy: firebase deploy --only firestore:rules
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isHaneulttangStore(storeId) {
      return storeId == "haneulttang" || storeId == "\uFEFFhaneulttang";
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isConfiguredAdmin(storeId) {
      return signedIn()
        && isHaneulttangStore(storeId)
        && (
          request.auth.uid == "E8HlEC6QH3YcAHqaBLgtvuc0Ab02"
          || request.auth.uid == "Hnu9dItMJ9WICgrOSeBntMN1Y993"
          || request.auth.token.email == "iu431214@gmail.com"
          || request.auth.token.email == "djmonnar4@gmail.com"
        );
    }

    function hasProfileInStore(storeId) {
      return hasUserProfile()
        && me().storeId == storeId
        && me().active == true;
    }

    function inStore(storeId) {
      return isConfiguredAdmin(storeId) || hasProfileInStore(storeId);
    }

    function isAdmin(storeId) {
      return isConfiguredAdmin(storeId) || (hasProfileInStore(storeId) && me().role == 'admin');
    }

    function isManager(storeId) {
      return hasProfileInStore(storeId) && me().role == 'manager';
    }

    function canManageOps(storeId) {
      return isAdmin(storeId) || isManager(storeId);
    }

    function isStaff(storeId) {
      return hasProfileInStore(storeId) && me().role == 'staff';
    }

    function isManageableRole(role) {
      return role == "staff" || role == "manager";
    }

    function pushEmployeeIdMatches() {
      return (
        ("employeeId" in me()) && request.resource.data.employeeId == me().employeeId
      ) || (
        !("employeeId" in me()) && request.resource.data.employeeId == null
      );
    }

    function isValidOwnPushToken() {
      return inStore(request.resource.data.storeId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.token is string
        && request.resource.data.token.size() > 20
        && request.resource.data.role == me().role
        && pushEmployeeIdMatches()
        && request.resource.data.enabled is bool
        && request.resource.data.email is string
        && (request.resource.data.email == request.auth.token.email || request.resource.data.email == "")
        && request.resource.data.platform is string
        && request.resource.data.userAgent is string
        && request.resource.data.keys().hasOnly([
          "storeId", "token", "uid", "email", "role", "employeeId",
          "platform", "userAgent", "enabled",
          "createdAt", "updatedAt", "lastSeenAt"
        ]);
    }

    function myEmpId() {
      return me().employeeId;
    }

    function isValidConfiguredAdminProfile() {
      return isHaneulttangStore(request.resource.data.storeId)
        && request.resource.data.active == true
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.role == "admin"
        && (!("employeeId" in request.resource.data) || request.resource.data.employeeId is number)
        && request.resource.data.keys().hasOnly([
          "name", "role", "storeId", "employeeId", "active",
          "phone", "address", "residentRegistrationNumber", "bank", "account", "createdAt", "updatedAt"
        ]);
    }

    // ---------- 사용자 프로필 ----------
    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin("haneulttang"));
      allow list: if isAdmin("haneulttang");

      allow create: if signedIn()
        && request.auth.uid == uid
        && (
          (
            isHaneulttangStore(request.resource.data.storeId)
            && request.resource.data.active == true
            && request.resource.data.name is string
            && request.resource.data.name.size() > 0
            && request.resource.data.role == "staff"
            && request.resource.data.employeeId is number
          )
          || (isConfiguredAdmin("haneulttang") && isValidConfiguredAdminProfile())
        );

      allow update: if signedIn()
        && (
          (
            request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.storeId == resource.data.storeId
            && request.resource.data.active == resource.data.active
            && (
              ("employeeId" in resource.data && request.resource.data.employeeId == resource.data.employeeId)
              || (!("employeeId" in resource.data) && !("employeeId" in request.resource.data))
            )
            && (
              ("createdAt" in resource.data && request.resource.data.createdAt == resource.data.createdAt)
              || (!("createdAt" in resource.data) && !("createdAt" in request.resource.data))
            )
            && request.resource.data.keys().hasOnly([
              "name", "role", "storeId", "employeeId", "active",
              "phone", "address", "residentRegistrationNumber", "bank", "account", "createdAt", "updatedAt"
            ])
          )
          || (
            isAdmin("haneulttang")
            && isManageableRole(request.resource.data.role)
            && request.resource.data.storeId == resource.data.storeId
            && request.resource.data.active == resource.data.active
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["role", "updatedAt"])
          )
          || (
            isAdmin("haneulttang")
            && request.resource.data.role == resource.data.role
            && request.resource.data.storeId == resource.data.storeId
            && request.resource.data.active == false
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["active", "updatedAt"])
          )
        );
      allow delete: if false;
    }

    // ---------- 매장 ----------
    match /stores/{storeId} {
      allow read: if inStore(storeId);
      allow write: if isAdmin(storeId);

      // 직원번호 카운터: 회원가입 트랜잭션에서 증가시켜야 하므로
      // 아직 프로필이 없는 로그인 사용자도 읽기 허용. employeeCounter 문서 1개만.
      match /meta/{docId} {
        allow read: if (
                      signedIn()
                      && isHaneulttangStore(storeId)
                      && docId == "employeeCounter"
                    )
                    || (
                      isAdmin(storeId)
                      && docId == "payrollPassword"
                    )
                    || (
                      isAdmin(storeId)
                      && docId == "notificationSettings"
                    );
        allow write: if (
                       signedIn()
                       && isHaneulttangStore(storeId)
                       && docId == "employeeCounter"
                       && request.resource.data.value is number
                       && request.resource.data.value > 0
                     )
                     || (
                       isAdmin(storeId)
                       && docId == "payrollPassword"
                       && request.resource.data.value is string
                       && request.resource.data.value.size() >= 4
                       && request.resource.data.keys().hasOnly(["value", "updatedAt"])
                     )
                     || (
                       isAdmin(storeId)
                       && docId == "notificationSettings"
                     );
      }

      match /pushTokens/{id} {
        allow get: if isAdmin(storeId)
                   || (signedIn() && resource.data.uid == request.auth.uid);
        allow list: if isAdmin(storeId);
        allow create: if signedIn()
                      && request.resource.data.storeId == storeId
                      && isValidOwnPushToken();
        allow update: if signedIn()
                      && resource.data.uid == request.auth.uid
                      && request.resource.data.storeId == resource.data.storeId
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.token == resource.data.token
                      && isValidOwnPushToken();
        allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      }

      match /notificationEvents/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /invalidPushTokens/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /employees/{id} {
        allow read: if inStore(storeId);
        // 관리자는 자유, 회원가입 시엔 본인 uid로 연결된 직원 문서만 자가 생성
        allow create: if isAdmin(storeId)
                      || (
                        signedIn()
                        && isHaneulttangStore(storeId)
                        && request.resource.data.uid == request.auth.uid
                        && request.resource.data.active == true
                        && request.resource.data.id is number
                        && request.resource.data.name is string
                        && request.resource.data.name.size() > 0
                        && request.resource.data.phone is string
                        && request.resource.data.address is string
                        && request.resource.data.residentRegistrationNumber is string
                        && request.resource.data.bank is string
                        && request.resource.data.account is string
                        && (request.resource.data.role == "홀" || request.resource.data.role == "주방")
                        && request.resource.data.employmentType == "partTime"
                        && request.resource.data.salaryType == "hourly"
                        && request.resource.data.hourly is number
                        && request.resource.data.keys().hasOnly([
                          "id", "name", "role", "employmentType", "salaryType", "hourly",
                          "phone", "address", "residentRegistrationNumber", "bank", "account", "uid", "active", "createdAt", "updatedAt"
                        ])
                      );
        allow update: if isAdmin(storeId)
                      || (
                        signedIn()
                        && isHaneulttangStore(storeId)
                        && resource.data.uid == request.auth.uid
                        && request.resource.data.uid == resource.data.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                          "name", "phone", "address", "residentRegistrationNumber",
                          "bank", "account", "updatedAt"
                        ])
                      );
        allow delete: if isAdmin(storeId);
      }

      match /reservations/{id} {
        allow read: if inStore(storeId);
        // 전화예약 입력/상태 변경/메모는 staff도 가능
        allow create, update: if inStore(storeId);
        allow delete: if isAdmin(storeId);
      }

      match /shifts/{id} {
        // staff는 본인 근무표만 (slot 모델은 employeeId, 기존 문서는 empId)
        allow read: if canManageOps(storeId)
                    || (isStaff(storeId)
                        && (resource.data.employeeId == myEmpId()
                            || resource.data.empId == myEmpId()));
        allow write: if canManageOps(storeId);
      }

      match /workRecords/{id} {
        allow read: if canManageOps(storeId)
                    || (isStaff(storeId) && resource.data.empId == myEmpId());
        allow create: if canManageOps(storeId)
                      || (isStaff(storeId) && request.resource.data.empId == myEmpId());
        allow update, delete: if canManageOps(storeId);
      }

      match /attendanceLogs/{id} {
        allow read: if canManageOps(storeId)
                    || (isStaff(storeId) && resource.data.empId == myEmpId());
        allow create: if canManageOps(storeId)
                      || (isStaff(storeId) && request.resource.data.empId == myEmpId());
        allow update, delete: if false; // 출퇴근 로그는 수정 불가
      }

      match /payroll/{id} {
        allow read: if isAdmin(storeId)
                    || (isStaff(storeId) && resource.data.empId == myEmpId());
        allow write: if isAdmin(storeId);
      }

      match /ownerSchedules/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /salesOrders/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /salesDailySummaries/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /salesSyncRuns/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /notices/{id} {
        allow read: if inStore(storeId);
        allow write: if canManageOps(storeId);
      }

      match /vendors/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /inventoryCategories/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /inventoryItems/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /purchaseOrders/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /stockLogs/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /recipes/{id} {
        allow read, write: if isAdmin(storeId);
      }

      match /handovers/{id} {
        allow read: if inStore(storeId);
        allow create: if inStore(storeId); // 전달사항은 누구나 남길 수 있음
        allow update, delete: if canManageOps(storeId);
      }

      match /chatbotUsers/{id} {
        allow read, write: if isAdmin(storeId);
      }
    }
  }
}
