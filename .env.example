# ============================================================
# 하늘땅 매장관리 — 환경변수 예시
#
# 이 파일을 복사해서 .env 로 만들고 값을 채워주세요.
#   cp .env.example .env
#
# 값은 Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱(웹) →
# SDK 설정 및 구성에서 확인할 수 있습니다.
#
# 주의: 여기에 들어가는 값은 "웹 API 키"로, 클라이언트에 노출되는
# 공개 식별자입니다. Admin SDK 서비스 계정 키(private key)는
# 절대 이 파일이나 프론트 코드에 넣지 마세요.
# ============================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# 매장 ID (Firestore stores/{storeId}). 기본값: haneulttang
VITE_FIREBASE_STORE_ID=haneulttang

# true 로 설정하면 Firebase 없이 목업 데이터 + 역할 전환 데모 모드로 동작
VITE_DEMO_MODE=false

# 선택: 매출 관리 화면의 "지금 동기화" 버튼이 호출할 Firebase Function URL
# 비워두면 https://asia-northeast3-{VITE_FIREBASE_PROJECT_ID}.cloudfunctions.net/syncOkposSales 를 사용합니다.
VITE_OKPOS_SYNC_FUNCTION_URL=
VITE_PUSH_TEST_FUNCTION_URL=

# OK포스 API 인증값은 프론트 .env가 아니라 Firebase Functions 환경변수/Secret으로 설정합니다.
# 예: OKPOS_BASE_URL, OKPOS_STORE_CODE, OKPOS_ORDERS_PATH, OKPOS_API_KEY
